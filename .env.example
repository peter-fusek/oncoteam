# Oncofiles MCP connection (REQUIRED)
ONCOFILES_MCP_URL=http://localhost:8000/mcp
ONCOFILES_MCP_TOKEN=your-oncofiles-token

# NCBI E-utilities (optional, increases rate limit)
# NCBI_API_KEY=

# Transport config
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Auth — REQUIRED for HTTP transport (auto-enforced, server won't start without them)
# MCP_BEARER_TOKEN=your-mcp-bearer-token
# DASHBOARD_API_KEY=your-dashboard-api-key
# DASHBOARD_ALLOWED_ORIGINS=https://your-dashboard.example.com
